# =============================================================================
# Environment Variables — Example / Defaults
# =============================================================================
# Copy this file to .env and fill in real values.
# NEVER commit .env — it is in .gitignore.
# AGENT: Document any new env vars here AND in ARCHITECTURE.md §8.
# =============================================================================

# Application
APP_PORT=8080
APP_ENV=development           # development | staging | production
LOG_LEVEL=debug               # debug | info | warn | error

# Database
DATABASE_URL=postgresql://appuser:apppassword@db:5432/appdb
DATABASE_POOL_SIZE=10

# External Services (replace with real service names)
# EXTERNAL_API_URL=https://api.example.com
# EXTERNAL_API_KEY=replace-me

# Security
# JWT_SECRET=replace-with-a-long-random-string
# ENCRYPTION_KEY=replace-with-32-char-secret
