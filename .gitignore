# =============================================================================
# .gitignore — Universal Language-Agnostic
# =============================================================================

# --- Environment & Secrets (NEVER commit these) ---
.env
.env.local
.env.*.local
*.pem
*.key
*.p12
*.pfx
secrets/
.secrets/

# --- OS & Editor artifacts ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*.swo
*~

# --- Node.js ---
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.npm/
dist/
build/
.next/
.nuxt/
.cache/
.parcel-cache/
coverage/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
dist/
build/
*.egg
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage
*.cover

# --- Go ---
*.exe
*.exe~
*.dll
*.so
*.dylib
/vendor/
/bin/
*.test
*.out

# --- Rust ---
target/
Cargo.lock   # Remove this line for binary projects (keep for libraries)

# --- Java / JVM ---
*.class
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar
target/
.gradle/
build/

# --- Docker ---
.docker/
docker-compose.override.yml

# --- Logs ---
logs/
*.log
*.log.*

# --- Test artifacts ---
.nyc_output/
test-results/
junit.xml

# --- Temporary files ---
tmp/
temp/
*.tmp
*.bak
*.orig
